<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>NStudio | La Chambre Noire</title>
<meta name="description" content="La Chambre Noire — Espace Premium NStudio pour travailler avec A.E.N.A.">

<meta property="og:title" content="NStudio | La Chambre Noire">
<meta property="og:description" content="Espace Premium NStudio — Assistance A.E.N.A.">
<meta property="og:image" content="Logo-NStudio.jpg">

<style>
:root{
    --bg:#020304;
    --text:#f4f0e8;
    --muted:#b9b0a3;
    --gold:#c79a4a;
    --gold-soft:#f0d28a;
    --mana:#1f9cff;
    --mana-soft:#7dd7ff;
    --line:rgba(240,210,138,.20);
    --glass:rgba(0,0,0,.50);
}

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

html{
    scroll-behavior:smooth;
}

body{
    font-family:Arial, Helvetica, sans-serif;
    color:var(--text);
    line-height:1.65;
    overflow-x:hidden;

    background:
        linear-gradient(rgba(0,0,0,.68),rgba(0,0,0,.90)),
        url("ArrierePlan-NStudio.png");

    background-size:46%;
    background-position:center top;
    background-repeat:no-repeat;
    background-attachment:fixed;
    background-color:var(--bg);
}

body::before{
    content:"";
    position:fixed;
    inset:0;
    pointer-events:none;
    z-index:-1;

    background:
        radial-gradient(circle at 50% 18%,rgba(31,156,255,.11),transparent 38%),
        radial-gradient(circle at 50% 72%,rgba(199,154,74,.08),transparent 56%);
}

body::after{
    content:"";
    position:fixed;
    inset:0;
    pointer-events:none;
    z-index:-2;

    background-image:
        linear-gradient(rgba(240,210,138,.013) 1px,transparent 1px),
        linear-gradient(90deg,rgba(240,210,138,.011) 1px,transparent 1px);

    background-size:90px 90px;
    mask-image:radial-gradient(circle at center,black 0%,transparent 78%);
    animation:gridMove 26s linear infinite;
}

@keyframes gridMove{
    from{background-position:0 0;}
    to{background-position:90px 90px;}
}

@keyframes floatLight{
    0%,100%{transform:translateY(0);}
    50%{transform:translateY(-8px);}
}

@keyframes pulseRing{
    0%,100%{
        box-shadow:
        0 0 50px rgba(31,156,255,.16),
        0 0 100px rgba(199,154,74,.10);
    }
    50%{
        box-shadow:
        0 0 85px rgba(31,156,255,.32),
        0 0 160px rgba(199,154,74,.18);
    }
}

a{
    color:inherit;
}

.page{
    width:min(1220px,calc(100% - 40px));
    margin:auto;
    padding:30px 0 90px;
}

.glass{
    border:1px solid var(--line);

    background:
        linear-gradient(135deg,rgba(255,255,255,.055),rgba(255,255,255,.014)),
        var(--glass);

    backdrop-filter:blur(16px);

    box-shadow:
        0 40px 140px rgba(0,0,0,.62),
        0 0 80px rgba(31,156,255,.06),
        0 0 100px rgba(199,154,74,.06);
}

.topbar{
    position:sticky;
    top:14px;
    z-index:100;

    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:18px;

    padding:13px 18px;

    border:1px solid var(--line);
    border-radius:999px;

    background:rgba(5,7,10,.82);
    backdrop-filter:blur(18px);

    box-shadow:0 18px 50px rgba(0,0,0,.42);
}

.brand{
    display:flex;
    align-items:center;
    gap:11px;

    font-weight:900;
    letter-spacing:.8px;
    white-space:nowrap;
}

.navbar-logo{
    width:42px;
    height:42px;

    border-radius:50%;
    object-fit:cover;

    border:1px solid rgba(240,210,138,.32);

    box-shadow:
        0 0 22px rgba(31,156,255,.18),
        0 0 42px rgba(199,154,74,.10);
}

.nav{
    display:flex;
    gap:14px;
    align-items:center;
    flex-wrap:wrap;

    font-size:14px;
    color:var(--muted);
}

.nav a{
    text-decoration:none;
    transition:.22s ease;
}

.nav a:hover{
    color:var(--gold-soft);
}

.chamber{
    min-height:calc(100vh - 120px);

    display:grid;
    place-items:center;

    padding-top:44px;
}

.chamber-card{
    width:100%;
    max-width:1080px;

    text-align:center;

    padding:76px 62px;

    border-radius:48px;

    position:relative;
    overflow:hidden;
}

.chamber-card::before{
    content:"";
    position:absolute;
    top:-260px;
    left:50%;
    transform:translateX(-50%);

    width:620px;
    height:620px;

    border-radius:50%;
    border:1px solid rgba(240,210,138,.12);

    animation:pulseRing 8s ease-in-out infinite;
}

.chamber-card > *{
    position:relative;
    z-index:2;
}

.chamber-logo{
    width:154px;

    border-radius:50%;

    margin-bottom:28px;

    box-shadow:
        0 0 55px rgba(31,156,255,.20),
        0 0 110px rgba(199,154,74,.14);

    animation:floatLight 7s ease-in-out infinite;
}

.badge{
    display:inline-flex;
    align-items:center;
    gap:9px;

    padding:8px 14px;

    border:1px solid var(--line);
    border-radius:999px;

    color:var(--gold-soft);
    background:rgba(0,0,0,.28);

    font-size:13px;
    letter-spacing:1.7px;
    text-transform:uppercase;

    margin-bottom:22px;
}

.badge::before{
    content:"";
    width:8px;
    height:8px;
    border-radius:50%;

    background:var(--mana-soft);
    box-shadow:0 0 16px rgba(31,156,255,.85);
}

h1{
    font-size:clamp(48px,7vw,90px);
    line-height:.92;
    letter-spacing:-3px;

    color:var(--text);

    text-shadow:
        0 10px 40px rgba(0,0,0,.55),
        0 0 34px rgba(199,154,74,.12);

    margin-bottom:18px;
}

h1 span,
h2,
h3{
    color:var(--gold-soft);
}

.intro{
    max-width:820px;

    margin:0 auto 18px;

    color:#e3dbcf;

    font-size:18px;
}

.warning{
    max-width:760px;

    margin:24px auto 0;
    padding:18px 22px;

    border-left:3px solid rgba(240,210,138,.45);

    background:
        linear-gradient(
            90deg,
            rgba(240,210,138,.08),
            transparent
        );

    text-align:left;
}

.warning strong{
    color:var(--gold-soft);
}

.protocol{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:16px;

    margin:42px 0 32px;
}

.protocol div{
    padding:22px;

    border-radius:24px;

    border:1px solid rgba(240,210,138,.14);

    background:rgba(0,0,0,.30);

    box-shadow:
        0 18px 55px rgba(0,0,0,.35),
        0 0 24px rgba(31,156,255,.05);
}

.protocol strong{
    display:block;

    color:var(--gold-soft);

    font-size:20px;

    margin-bottom:8px;
}

.protocol span{
    color:var(--muted);
}

.matrix{
    margin:44px auto 0;

    display:grid;
    grid-template-columns:repeat(5,1fr);
    gap:12px;

    max-width:920px;
}

.matrix-item{
    padding:16px 10px;

    border-radius:20px;

    border:1px solid rgba(31,156,255,.18);

    background:
        linear-gradient(
            135deg,
            rgba(31,156,255,.08),
            rgba(0,0,0,.34)
        );
}

.matrix-item strong{
    display:block;

    color:var(--gold-soft);

    font-size:14px;
    letter-spacing:1px;

    margin-bottom:4px;
}

.matrix-item span{
    color:var(--muted);

    font-size:13px;
}

.actions{
    display:flex;
    flex-wrap:wrap;
    gap:14px;

    justify-content:center;

    margin-top:42px;
}

.btn{
    display:inline-flex;
    align-items:center;
    justify-content:center;

    min-height:52px;

    padding:14px 24px;

    border-radius:999px;

    text-decoration:none;

    font-weight:900;
    letter-spacing:1px;

    border:1px solid var(--line);

    transition:.25s ease;
}

.btn:hover{
    transform:translateY(-3px);
}

.btn-mana{
    color:#02111a;

    background:
        linear-gradient(135deg,#ffffff,#bfeaff,#1f9cff);

    box-shadow:
        0 0 35px rgba(31,156,255,.28);
}

.btn-dark{
    color:var(--text);
    background:rgba(0,0,0,.28);
}

.btn-gold{
    color:#070503;

    background:
        linear-gradient(135deg,#fff5d5,#e6c477,#a97422);

    box-shadow:
        0 0 32px rgba(199,154,74,.22);
}

.footer{
    text-align:center;

    color:var(--muted);

    margin-top:42px;
    padding-bottom:20px;

    font-size:14px;
}

@media(max-width:900px){

    body{
        background-size:96%;
        background-attachment:scroll;
    }

    .page{
        width:min(100% - 28px,720px);
        padding:22px 0 64px;
    }

    .topbar{
        position:static;
        border-radius:22px;
        flex-direction:column;
        align-items:flex-start;
    }

    .chamber-card{
        padding:46px 26px;
        border-radius:34px;
    }

    .protocol,
    .matrix{
        grid-template-columns:1fr;
    }

    .actions{
        flex-direction:column;
    }

    .btn{
        width:100%;
    }

    h1{
        letter-spacing:-2px;
    }
}
</style>
</head>

<body>

<main class="page">

<header class="topbar">

    <div class="brand">
        <img src="Logo-NStudio.jpg" alt="Logo NStudio" class="navbar-logo">
        <div>NStudio</div>
    </div>

    <nav class="nav" aria-label="Navigation principale">
        <a href="index.html">Accueil</a>
        <a href="plateforme.html">Plateforme</a>
        <a href="#protocole">Protocole</a>
        <a href="#matrice">Matrice</a>
        <a href="#acces">Accès</a>
    </nav>

</header>

<section class="chamber" id="acces">

    <div class="chamber-card glass">

        <img
        src="Logo-NStudio.jpg"
        alt="Logo NStudio"
        class="chamber-logo">

        <div class="badge">
            Espace Premium • A.E.N.A
        </div>

        <h1>La Chambre <span>Noire</span></h1>

        <p class="intro">
            La Chambre Noire est l’espace réservé aux clients Premium NStudio.
            Ici, A.E.N.A aide à clarifier, structurer, organiser et transformer les idées en actions concrètes.
        </p>

        <p class="intro">
            Ce n’est pas une simple messagerie.
            C’est un atelier de travail numérique.
        </p>

        <div class="warning">
            <p>
                <strong>Principe fondamental :</strong>
                nous commençons toujours par comprendre avant d’agir.
                L’assistance n’impose pas une réponse : elle révèle la prochaine étape utile.
            </p>
        </div>

        <div class="protocol" id="protocole">

            <div>
                <strong>Comprendre</strong>
                <span>Identifier le besoin réel, la situation et le blocage.</span>
            </div>

            <div>
                <strong>Structurer</strong>
                <span>Transformer le flou en plan, tableau, étapes ou agenda.</span>
            </div>

            <div>
                <strong>Agir</strong>
                <span>Produire la prochaine action claire, simple et réalisable.</span>
            </div>

        </div>

        <div class="matrix" id="matrice">

            <div class="matrix-item">
                <strong>Organisation</strong>
                <span>planning</span>
            </div>

            <div class="matrix-item">
                <strong>Tableaux</strong>
                <span>suivi</span>
            </div>

            <div class="matrix-item">
                <strong>Contenus</strong>
                <span>rédaction</span>
            </div>

            <div class="matrix-item">
                <strong>Stratégie</strong>
                <span>direction</span>
            </div>

            <div class="matrix-item">
                <strong>Transmission</strong>
                <span>clarté</span>
            </div>

        </div>

        <div class="actions">

            <a
            class="btn btn-mana"
            href="https://chatgpt.com/g/g-681b86f1f87c8191b695e33446183ea3-a-e-n-a-anima-echo-de-la-nouvelle-aube"
            target="_blank"
            rel="noopener noreferrer">
                ◈ Travailler avec A.E.N.A
            </a>

            <a class="btn btn-dark" href="plateforme.html">
                Retour au bureau
            </a>

            <a
            class="btn btn-gold"
            href="mailto:romain.tonolli@aol.fr?subject=Acces%20Premium%20NStudio">
                Demander un accès Premium
            </a>

        </div>

    </div>

</section>

<div class="footer">
    NStudio — La Chambre Noire • A.E.N.A • Organisation • Stratégie • Transmission
</div>

</main>

</body>
</html>
